{
    "family": "nithin-strapi-v6-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "strapi",
            "image": "strapi/strapi:latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 1337,
                    "hostPort": 1337,
                    "protocol": "tcp"
                }
            ]
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::811738710312:role/ecs_fargate_taskRole",
    "taskRoleArn": "arn:aws:iam::811738710312:role/ecs_fargate_taskRole"
}